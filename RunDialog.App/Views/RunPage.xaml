<?xml version="1.0" encoding="UTF-8"?>
<Page
    x:Class="RunDialog.App.Views.RunPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:converters="using:RunDialog.App.Converters"
    Background="Transparent"
    mc:Ignorable="d">

    <Page.Resources>
        <SolidColorBrush x:Key="ErrorBrush" Color="#C42B1C"/>
        <converters:BoolToErrorBrushConverter x:Key="BoolToErrorBrushConverter"/>
        <converters:EmptyStringToVisibilityConverter x:Key="EmptyStringToVisibilityConverter"/>
    </Page.Resources>

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Custom Title Bar -->
        <Grid x:Name="CustomTitleBar" Grid.Row="0" Height="32" Background="Transparent" ColumnDefinitions="Auto,*">
            <FontIcon Grid.Column="0" Glyph="&#xE768;" FontSize="16" Margin="12,0,8,0" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
            <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.WindowTitle, Mode=OneWay}" VerticalAlignment="Center" FontSize="12" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
        </Grid>

        <!-- Content -->
        <Grid Grid.Row="1" Padding="24,0,24,24" Background="Transparent">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header with icon and description -->
                <Grid Grid.Row="0" ColumnDefinitions="Auto,*" Margin="0,0,0,12">
                    <FontIcon
                        Grid.Column="0"
                        Glyph="&#xE768;"
                        FontSize="24"
                        Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                        VerticalAlignment="Top"
                        Margin="0,2,12,0"/>
                    <TextBlock
                        Grid.Column="1"
                        Text="{x:Bind ViewModel.DescriptionText, Mode=OneWay}"
                        TextWrapping="Wrap"
                        FontSize="13"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </Grid>

                <!-- Command input -->
                <Grid Grid.Row="1" ColumnDefinitions="Auto,*" Margin="0,8,0,8">
                    <TextBlock
                        Grid.Column="0"
                        Text="{x:Bind ViewModel.OpenPrompt, Mode=OneWay}"
                        VerticalAlignment="Center"
                        Margin="0,0,8,0"
                        FontSize="13"/>
                    <AutoSuggestBox
                        x:Name="CommandInput"
                        Grid.Column="1"
                        Text="{x:Bind ViewModel.CommandText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        ItemsSource="{x:Bind ViewModel.FilteredHistory, Mode=OneWay}"
                        PlaceholderText="{x:Bind ViewModel.PlaceholderText, Mode=OneWay}"
                        HorizontalAlignment="Stretch"
                        FontSize="14"/>
                </Grid>

                <!-- Run as admin checkbox -->
                <CheckBox
                    Grid.Row="2"
                    Content="{x:Bind ViewModel.RunAsAdminText, Mode=OneWay}"
                    IsChecked="{x:Bind ViewModel.RunAsAdmin, Mode=TwoWay}"
                    Margin="0,4,0,4"
                    FontSize="12"/>

                <!-- Status / Error message -->
                <TextBlock
                    Grid.Row="3"
                    Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                    TextWrapping="Wrap"
                    FontSize="12"
                    Margin="0,4,0,8"
                    Foreground="{x:Bind ViewModel.IsError, Mode=OneWay, Converter={StaticResource BoolToErrorBrushConverter}}"
                    Visibility="{x:Bind ViewModel.StatusMessage, Mode=OneWay, Converter={StaticResource EmptyStringToVisibilityConverter}}"/>

                <!-- Buttons -->
                <Grid Grid.Row="4" ColumnDefinitions="*,Auto,Auto,Auto" Margin="0,12,0,0">
                    <Button
                        Grid.Column="1"
                        Content="{x:Bind ViewModel.OkButton, Mode=OneWay}"
                        Command="{x:Bind ViewModel.RunCommand, Mode=OneWay}"
                        Style="{StaticResource AccentButtonStyle}"
                        MinWidth="80"
                        Margin="0,0,8,0"/>
                    <Button
                        Grid.Column="2"
                        Content="{x:Bind ViewModel.CancelButton, Mode=OneWay}"
                        Command="{x:Bind ViewModel.CancelCommand, Mode=OneWay}"
                        MinWidth="80"
                        Margin="0,0,8,0"/>
                    <Button
                        Grid.Column="3"
                        Content="{x:Bind ViewModel.BrowseButton, Mode=OneWay}"
                        Command="{x:Bind ViewModel.BrowseCommand, Mode=OneWay}"
                        MinWidth="80"/>
                </Grid>

                <!-- Options expander -->
                <Expander x:Name="OptionsExpander" Grid.Row="5" Margin="0,16,0,0" HorizontalAlignment="Stretch" IsExpanded="{x:Bind ViewModel.ShowOptions, Mode=TwoWay}">
                    <Expander.Header>
                        <TextBlock Text="{x:Bind ViewModel.OptionsTitle, Mode=OneWay}" FontSize="13" FontWeight="SemiBold"/>
                    </Expander.Header>
                    <Grid Padding="0,8,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" ColumnDefinitions="Auto,*" Margin="0,0,0,8">
                            <TextBlock Grid.Column="0" Text="{x:Bind ViewModel.ThemeLabel, Mode=OneWay}" VerticalAlignment="Center" Margin="0,0,12,0" FontSize="13"/>
                            <ComboBox Grid.Column="1" SelectedValue="{x:Bind ViewModel.Theme, Mode=TwoWay}" SelectedValuePath="Tag" HorizontalAlignment="Stretch">
                                <ComboBoxItem Content="{x:Bind ViewModel.ThemeAuto, Mode=OneWay}" Tag="Auto"/>
                                <ComboBoxItem Content="{x:Bind ViewModel.ThemeLight, Mode=OneWay}" Tag="Light"/>
                                <ComboBoxItem Content="{x:Bind ViewModel.ThemeDark, Mode=OneWay}" Tag="Dark"/>
                            </ComboBox>
                        </Grid>
                        <Grid Grid.Row="1" ColumnDefinitions="Auto,*" Margin="0,0,0,8">
                            <TextBlock Grid.Column="0" Text="{x:Bind ViewModel.BackdropLabel, Mode=OneWay}" VerticalAlignment="Center" Margin="0,0,12,0" FontSize="13"/>
                            <ComboBox Grid.Column="1" SelectedValue="{x:Bind ViewModel.Backdrop, Mode=TwoWay}" SelectedValuePath="Tag" HorizontalAlignment="Stretch">
                                <ComboBoxItem Content="{x:Bind ViewModel.BackdropMica, Mode=OneWay}" Tag="Mica"/>
                                <ComboBoxItem Content="{x:Bind ViewModel.BackdropMicaAlt, Mode=OneWay}" Tag="MicaAlt"/>
                                <ComboBoxItem Content="{x:Bind ViewModel.BackdropAcrylic, Mode=OneWay}" Tag="Acrylic"/>
                            </ComboBox>
                        </Grid>
                    </Grid>
                </Expander>

                <!-- Bottom actions row -->
                <Grid Grid.Row="6" ColumnDefinitions="Auto,*,Auto" Margin="0,8,0,0">
                    <HyperlinkButton
                        Grid.Column="0"
                        Content="{x:Bind ViewModel.AboutTitle, Mode=OneWay}"
                        Command="{x:Bind ViewModel.ShowAboutCommand, Mode=OneWay}"
                        FontSize="11"/>
                    <HyperlinkButton
                        Grid.Column="2"
                        Content="PL / EN"
                        Command="{x:Bind ViewModel.ToggleLanguageCommand, Mode=OneWay}"
                        FontSize="11"/>
                </Grid>
            </Grid>
    </Grid>
</Page>
